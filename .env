cd ~/nextcloud
nano .env

# Database
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT
MYSQL_DATABASE=nextcloud_db
MYSQL_USER=nextcloud_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_USER

# Optional: Nextcloud admin bootstrap (only used on first install if you add the env vars in compose)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN
